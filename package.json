{
  "name": "context-mri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -b && vite build && npm run build:worker",
    "build:worker": "esbuild server/site-worker.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/server/index.js",
    "evidence:live": "tsx scripts/generate-live-evidence.ts",
    "test": "tsx --test server/**/*.test.ts",
    "start": "tsx server/index.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "lucide-react": "1.25.0",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.5"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
